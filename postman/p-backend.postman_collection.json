{
  "info": {
    "_postman_id": "d0b9c2c8-8d59-4f39-bf64-9a7aa7b2b6d4",
    "name": "p-backend API",
    "description": "Postman collection generated from the Express routes in this repository. Uses {{baseUrl}} with a default of http://localhost:5000/api/v1. Login and refresh requests store tokens in collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:5000/api/v1');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
